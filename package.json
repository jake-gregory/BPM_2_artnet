{
  "name": "bpm_2_artnet",
  "version": "1.0.0",
  "description": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jake-gregory/BPM_2_artnet.git"
  },
  "homepage": "https://github.com/jake-gregory/BPM_2_artnet#readme",
  "bugs": {
    "url": "https://github.com/jake-gregory/BPM_2_artnet/issues"
  },
  "main": "dist/index.js",
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "postinstall": "node scripts/check-dependencies.js"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.ts": [
      "bash -c 'npm run type-check'"
    ]
  },
  "keywords": [],
  "author": "Jake Gregory",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "artnet": "^1.4.0",
    "music-tempo": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitest/eslint-plugin": "^1.5.2",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
